{
    "swagger": "2.0",
    "info": {
        "description": "For login, logout, refresh token and make account",
        "title": "Auth-Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:7070",
    "paths": {
        "/authService.AuthService/Login": {
            "post": {
                "description": "login for get access",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "login for get access",
                "parameters": [
                    {
                        "description": "account data",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth.LoginData"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success login",
                        "schema": {
                            "$ref": "#/definitions/dto.ResponseLogin"
                        }
                    },
                    "500": {
                        "description": "if error internal",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorInternal"
                        }
                    }
                }
            }
        },
        "/authService.AuthService/Logout": {
            "post": {
                "security": [
                    {
                        "Access-Token": [],
                        "Refresh-Token": []
                    }
                ],
                "description": "logout",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "logout",
                "parameters": [
                    {
                        "description": "empty",
                        "name": "data",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/dto.Empty"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success login",
                        "schema": {
                            "$ref": "#/definitions/dto.ResponseLogout"
                        }
                    },
                    "500": {
                        "description": "if error internal",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorInternal"
                        }
                    }
                }
            }
        },
        "/authService.AuthService/Refresh": {
            "post": {
                "security": [
                    {
                        "Refresh-Token": []
                    }
                ],
                "description": "for get a new token",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "for get a new token",
                "parameters": [
                    {
                        "description": "empty",
                        "name": "data",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/dto.Empty"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success login",
                        "schema": {
                            "$ref": "#/definitions/dto.ResponseRefresh"
                        }
                    },
                    "500": {
                        "description": "if error internal",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorInternal"
                        }
                    }
                }
            }
        },
        "/authService.AuthService/Register": {
            "post": {
                "description": "make account or register",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "make account or register",
                "parameters": [
                    {
                        "type": "string",
                        "description": "idempotency key",
                        "name": "Idempotency-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "account data",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth.UserData"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success register",
                        "schema": {
                            "$ref": "#/definitions/dto.ResponseRegister"
                        }
                    },
                    "500": {
                        "description": "if error internal",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorInternal"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "auth.LoginData": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "nik": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "auth.UserData": {
            "type": "object",
            "properties": {
                "city": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "nik": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "province": {
                    "type": "string"
                }
            }
        },
        "dto.Empty": {
            "type": "object"
        },
        "dto.ErrorInternal": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "internal"
                },
                "error": {
                    "type": "string",
                    "example": "an error occured"
                }
            }
        },
        "dto.ResponseLogin": {
            "type": "object",
            "properties": {
                "Message": {
                    "type": "string",
                    "example": "successfully login"
                },
                "Status": {
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "dto.ResponseLogout": {
            "type": "object",
            "properties": {
                "Message": {
                    "type": "string",
                    "example": "successfully logout"
                },
                "Status": {
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "dto.ResponseRefresh": {
            "type": "object",
            "properties": {
                "Message": {
                    "type": "string",
                    "example": "successfully refresh token"
                },
                "Status": {
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "dto.ResponseRegister": {
            "type": "object",
            "properties": {
                "Message": {
                    "type": "string",
                    "example": "registered successfully"
                },
                "Status": {
                    "type": "boolean",
                    "example": true
                }
            }
        }
    },
    "securityDefinitions": {
        "Access-Token": {
            "type": "apiKey",
            "name": "AccessToken",
            "in": "cookie"
        },
        "Refresh-Token": {
            "type": "apiKey",
            "name": "RefreshToken",
            "in": "cookie"
        }
    }
}